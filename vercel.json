{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/registrations",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/admin/registrations",
      "destination": "https://lmzftlvxoncqdonbkcyd.supabase.co/functions/v1/admin-registrations"
    },
    {
      "source": "/api/admin/registrations/:id/decision",
      "destination": "https://lmzftlvxoncqdonbkcyd.supabase.co/functions/v1/admin-decision?id=:id"
    },
    {
      "source": "/api/admin/registrations/:id/invoice",
      "destination": "https://lmzftlvxoncqdonbkcyd.supabase.co/functions/v1/admin-invoice?id=:id"
    },
    {
      "source": "/api/admin/registrations/:id/custom-email",
      "destination": "https://lmzftlvxoncqdonbkcyd.supabase.co/functions/v1/admin-custom-email?id=:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
